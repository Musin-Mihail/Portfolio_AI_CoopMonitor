{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=coop_monitor.db;Cache=Shared"
  },
  "Jwt": {
    "Key": "THIS_IS_A_VERY_SECURE_SECRET_KEY_FOR_DEVELOPMENT_ONLY_CHANGE_IT_IN_PROD!",
    "Issuer": "CoopMonitorAPI",
    "Audience": "CoopMonitorClient",
    "ExpireDays": 7
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "admin",
    "SecretKey": "SuperSecretPassword123!",
    "BucketName": "default"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/coop-monitor-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedOrigins": ["http://localhost:4200"],
  "AllowedHosts": "*"
}
